@model List<EntityMeta>
@{
    ViewData["Title"] = "CMDB Dashboard";
}
<h1 class="mb-4">CMDB Dashboard</h1>

<form method="post" action="/create_table" class="mb-4">
    <div class="input-group input-group-lg">
        <input type="text" id="entitySearch" name="table_name" class="form-control" placeholder="Search or create table..." autofocus/>
        <button type="submit" id="createBtn" class="btn btn-danger d-none">
            <i class="bi bi-plus-circle me-1"></i>Create
        </button>
    </div>
</form>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-3" id="entityGrid">
    @foreach (var e in Model)
    {
        <div class="col entity-card" data-name="@e.DisplayName.ToLower()" data-desc="@e.Description.ToLower()">
            <a href="/entity/@e.TableName" class="text-decoration-none">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi @e.Icon me-2"></i>@e.DisplayName</h5>
                        <p class="card-text text-muted small">@e.Description</p>
                    </div>
                </div>
            </a>
        </div>
    }
</div>
<p id="noResults" class="text-muted text-center mt-4 d-none">No matching entities found.</p>

@section Scripts {
<script>
(function(){
    var input = document.getElementById('entitySearch');
    var btn = document.getElementById('createBtn');
    var cards = document.querySelectorAll('.entity-card');
    var noResults = document.getElementById('noResults');

    input.addEventListener('input', function(){
        var f = this.value.toLowerCase().trim();
        var vis = 0;
        cards.forEach(function(c){
            var m = !f || c.dataset.name.includes(f) || c.dataset.desc.includes(f);
            c.style.display = m ? '' : 'none';
            if(m) vis++;
        });
        noResults.classList.toggle('d-none', vis > 0 || !f);
        // Show create button when text is entered and no exact match
        var exact = false;
        if(f) {
            cards.forEach(function(c){ if(c.dataset.name === f) exact = true; });
        }
        btn.classList.toggle('d-none', !f || exact);
    });
}());
</script>
}
