@{
    var entity = (EntityMeta)ViewBag.Entity;
    var tableName = (string)ViewBag.TableName;
    var row = (Dictionary<string, object?>)ViewBag.Row;
    var fkOptions = (Dictionary<string, List<Dictionary<string, object?>>>)ViewBag.FkOptions;
    ViewData["Title"] = "Edit " + entity.DisplayName;
}
<h1>Edit @entity.DisplayName</h1>
<hr/>
@{
    var pkParams = string.Join("&", entity.PkColumns.Select(pk => $"{pk}={Uri.EscapeDataString(row.ContainsKey(pk) ? row[pk]?.ToString() ?? "" : "")}"));
}
<form id="addColForm" method="post" action="/add_column/@tableName">
    <input type="hidden" name="return_url" value="/entity/@tableName/edit?@pkParams"/>
    <input type="hidden" name="nullable" value="on"/>
</form>
<div class="row">
    <div class="col-md-6">
        <form method="post" action="/entity/@tableName/edit">
            @foreach (var pk in entity.PkColumns)
            {
                <input type="hidden" name="@pk" value="@(row.ContainsKey(pk) ? row[pk]?.ToString() : "")"/>
            }
            @foreach (var col in entity.Columns)
            {
                if (entity.PkColumns.Contains(col.ColumnName))
                {
                    continue;
                }
                var val = row.ContainsKey(col.ColumnName) ? row[col.ColumnName]?.ToString() ?? "" : "";
                if (col.IsFk)
                {
                    var navName = col.FkNavName ?? SchemaService.SplitPascal(col.FkRefTable!);
                    var opts = fkOptions.ContainsKey(col.ColumnName) ? fkOptions[col.ColumnName] : new List<Dictionary<string, object?>>();
                    var selectedText = "";
                    foreach (var opt in opts)
                    {
                        if (opt["PK"]?.ToString() == val)
                        {
                            selectedText = opt["DISPLAY"]?.ToString() ?? "";
                        }
                    }
                    <div class="form-group mb-2 fk-wrapper row align-items-center">
                        <label class="control-label col-sm-3 col-form-label">@navName</label>
                        <div class="col-sm-9">
                        <input type="hidden" name="@col.ColumnName" id="@col.ColumnName" value="@val"/>
                        <input type="text" class="form-control fk-autocomplete" id="display_@col.ColumnName"
                               value="@selectedText" data-target="@col.ColumnName" autocomplete="off"/>
                        <div class="fk-dropdown" id="dropdown_@col.ColumnName">
                            @foreach (var opt in opts)
                            {
                                <div class="fk-option" data-id="@opt["PK"]" data-text="@opt["DISPLAY"]">@opt["DISPLAY"]</div>
                            }
                        </div>
                        </div>
                    </div>
                }
                else
                {
                    var label = SchemaService.SplitPascal(col.ColumnName);
                    var dt = col.DataType.ToUpper();
                    <div class="form-group mb-2 row align-items-center">
                        <label class="control-label col-sm-3 col-form-label" for="@col.ColumnName">@label</label>
                        <div class="col-sm-9">
                        @if (dt.Contains("NUMBER") || dt.Contains("INT"))
                        {
                            <input name="@col.ColumnName" class="form-control" type="number" value="@val"/>
                        }
                        else if (dt == "DATE")
                        {
                            <input name="@col.ColumnName" class="form-control" type="date" value="@(val.Length >= 10 ? val.Substring(0, 10) : val)"/>
                        }
                        else if (dt.Contains("TIMESTAMP"))
                        {
                            <input name="@col.ColumnName" class="form-control" type="datetime-local" value="@(val.Length >= 16 ? val.Substring(0, 16) : val)"/>
                        }
                        else
                        {
                            <input name="@col.ColumnName" class="form-control" type="text" value="@val"/>
                        }
                        </div>
                    </div>
                }
            }
            <hr class="my-3"/>
            <div class="form-group mb-3 row align-items-center">
                <label class="col-sm-3 col-form-label text-muted">New column</label>
                <div class="col-sm-9">
                    <div class="input-group">
                        <input type="text" name="column_name" form="addColForm" class="form-control" placeholder="Column name..."/>
                        <button type="submit" form="addColForm" class="btn btn-outline-secondary">
                            <i class="bi bi-plus-lg"></i> Add
                        </button>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-danger"/>
                <a href="/entity/@tableName/delete?@pkParams" class="btn btn-outline-danger ms-2">Delete</a>
            </div>
        </form>
    </div>
</div>
<div class="mt-3"><a href="/entity/@tableName">Back to List</a></div>

@section Scripts {
<script src="/js/fk-autocomplete.js"></script>
}
