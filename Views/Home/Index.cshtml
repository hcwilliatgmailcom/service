@using service.Services
@inject EntityMetadataService MetadataService
@{
    ViewData["Title"] = "CMDB Dashboard";
}

<h1 class="mb-4">CMDB Dashboard</h1>

<div class="mb-4">
    <input type="text" id="entitySearch" class="form-control form-control-lg" placeholder="Search entities..." autofocus />
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-3" id="entityGrid">
    @foreach (var entity in MetadataService.GetAllEntities())
    {
        <div class="col entity-card" data-name="@entity.DisplayName.ToLower()" data-desc="@entity.Description.ToLower()">
            <a asp-controller="@entity.DbSetName" asp-action="Index" class="text-decoration-none">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="bi @entity.Icon me-2"></i>@entity.DisplayName
                        </h5>
                        <p class="card-text text-muted small">@entity.Description</p>
                    </div>
                </div>
            </a>
        </div>
    }
</div>

<p id="noResults" class="text-muted text-center mt-4 d-none">No matching entities found.</p>

@section Scripts {
    <script>
        document.getElementById('entitySearch').addEventListener('input', function () {
            var filter = this.value.toLowerCase();
            var cards = document.querySelectorAll('.entity-card');
            var visible = 0;
            cards.forEach(function (card) {
                var name = card.getAttribute('data-name');
                var desc = card.getAttribute('data-desc');
                var match = name.includes(filter) || desc.includes(filter);
                card.style.display = match ? '' : 'none';
                if (match) visible++;
            });
            document.getElementById('noResults').classList.toggle('d-none', visible > 0);
        });
    </script>
}
