@{
    ViewData["Title"] = ((EntityMeta)ViewBag.Entity).DisplayName;
    var entity = (EntityMeta)ViewBag.Entity;
    var tableName = (string)ViewBag.TableName;
    var columns = (List<DisplayColumn>)ViewBag.Columns;
    var colNames = (List<string>)ViewBag.ColNames;
    var rows = (List<Dictionary<string, object?>>)ViewBag.Rows;
    var pkCols = (List<string>)ViewBag.PkCols;
    var fkDisplayMap = (Dictionary<string, (string alias, string displayMember, string navName)>)ViewBag.FkDisplayMap;
    var search = (string)ViewBag.Search;
    var sort = (string)ViewBag.Sort;
    var sortDir = (string)ViewBag.SortDir;
    var page = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;
}
<h1>@entity.DisplayName</h1>

@if (!entity.IsView)
{
    <form id="dropTableForm" method="post" action="/drop_table/@tableName"></form>
    <form id="createForm" method="post" action="/entity/@tableName/create"></form>
}
<form method="get" action="/entity/@tableName" class="mb-3">
    <div class="input-group">
        <input type="text" name="search" value="@search" class="form-control" placeholder="Search..."/>
        <button type="submit" class="btn btn-primary"><i class="bi bi-search me-1"></i>Search</button>
        @if (!string.IsNullOrEmpty(search))
        {
            <a href="/entity/@tableName" class="btn btn-outline-secondary">Clear</a>
        }
        @if (!entity.IsView)
        {
            <button type="submit" form="createForm" class="btn btn-danger">
                <i class="bi bi-plus-circle me-1"></i>Create
            </button>
            <button type="submit" form="dropTableForm" class="btn btn-outline-danger">
                <i class="bi bi-trash me-1"></i>Drop
            </button>
        }
    </div>
</form>

<div class="table-responsive">
<table class="table table-striped">
    <thead>
        <tr>
        <th></th>
        @foreach (var col in columns)
        {
            var newDir = (sort == col.SortKey && sortDir == "asc") ? "desc" : "asc";
            <th>
                <a href="/entity/@tableName?search=@Uri.EscapeDataString(search)&sort=@Uri.EscapeDataString(col.SortKey)&dir=@newDir">
                    @(col.IsFk ? col.Name.ToUpper() : col.Name)
                    @if (sort == col.SortKey)
                    {
                        <i class="bi bi-caret-@(sortDir == "asc" ? "up" : "down")-fill"></i>
                    }
                </a>
            </th>
        }
        </tr>
    </thead>
    <tbody>
        @foreach (var row in rows)
        {
            var pkParams = string.Join("&", pkCols.Select(pk => $"{pk}={Uri.EscapeDataString(row[pk]?.ToString() ?? "")}"));
            var pkLabel = string.Join(", ", pkCols.Select(pk => row[pk]?.ToString() ?? ""));
            <tr>
                <td class="text-nowrap">
                    @if (pkCols.Count > 0)
                    {
                        if (entity.IsView)
                        {
                            <a href="/entity/@tableName/details?@pkParams" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-eye me-1"></i>@pkLabel
                            </a>
                        }
                        else
                        {
                            <a href="/entity/@tableName/edit?@pkParams" class="btn btn-sm btn-primary">@pkLabel</a>
                        }
                    }
                </td>
                @foreach (var col in columns)
                {
                    if (col.IsFk)
                    {
                        <td>@(row.ContainsKey(col.Name) ? row[col.Name]?.ToString() ?? "" : "")</td>
                    }
                    else
                    {
                        var colIdx = colNames.IndexOf(col.SortKey);
                        var colKey = colIdx >= 0 ? colNames[colIdx] : col.SortKey;
                        <td>@(row.ContainsKey(colKey) ? row[colKey]?.ToString() ?? "" : "")</td>
                    }
                }
            </tr>
        }
    </tbody>
</table>
</div>

<div class="d-flex justify-content-between align-items-center">
    <nav>
        <ul class="pagination mb-0">
            @if (page > 1)
            {
                <li class="page-item"><a class="page-link" href="/entity/@tableName?search=@Uri.EscapeDataString(search)&sort=@Uri.EscapeDataString(sort)&dir=@sortDir&page=@(page-1)">Previous</a></li>
            }
            else
            {
                <li class="page-item disabled"><span class="page-link">Previous</span></li>
            }
            <li class="page-item disabled"><span class="page-link">@($"Page {page} of {totalPages}")</span></li>
            @if (page < totalPages)
            {
                <li class="page-item"><a class="page-link" href="/entity/@tableName?search=@Uri.EscapeDataString(search)&sort=@Uri.EscapeDataString(sort)&dir=@sortDir&page=@(page+1)">Next</a></li>
            }
            else
            {
                <li class="page-item disabled"><span class="page-link">Next</span></li>
            }
        </ul>
    </nav>
    <div>
        <a href="/entity/@tableName/export" class="btn btn-warning me-1">
            <i class="bi bi-download me-1"></i>Export CSV
        </a>
        @if (!entity.IsView)
        {
            <form method="post" action="/entity/@tableName/import" enctype="multipart/form-data" class="d-inline-block">
                <label class="btn btn-warning mb-0">
                    <i class="bi bi-upload me-1"></i>Import CSV
                    <input type="file" name="file" accept=".csv" class="d-none" onchange="this.form.submit();"/>
                </label>
            </form>
        }
        @if ((bool)ViewBag.Syncable)
        {
            <form method="post" action="/entity/@tableName/sync" class="d-inline">
                <button type="submit" class="btn btn-warning"><i class="bi bi-arrow-repeat me-1"></i>Sync</button>
            </form>
        }
    </div>
</div>
