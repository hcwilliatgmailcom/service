@model List<EntityMeta>
@{
    ViewData["Title"] = "Schema Management";
    var allEntities = (List<EntityMeta>)ViewBag.AllEntities;
}
<h1 class="mb-4"><i class="bi bi-diagram-3 me-2"></i>Schema Management</h1>

<div class="card mb-4">
    <div class="card-body">
        <form method="post" action="/create_table">
            <div class="input-group">
                <input type="text" id="schemaSearch" name="table_name" class="form-control" placeholder="Filter or create table..." autofocus/>
                <button type="submit" class="btn btn-danger"><i class="bi bi-plus-circle me-1"></i>Create</button>
            </div>
        </form>
    </div>
</div>

@foreach (var entity in Model)
{
    var tableName = entity.TableName;
    var pkCols = entity.PkColumns;

    @* Forms defined outside the table to avoid invalid nested form HTML *@
    <form id="add-col-@tableName" method="post" action="/add_column/@tableName"></form>
    <form id="drop-tbl-@tableName" method="post" action="/drop_table/@tableName"></form>

    foreach (var col in entity.Columns)
    {
        var isPk = pkCols.Contains(col.ColumnName);
        if (!isPk && !col.ColumnName.Equals("NAME", StringComparison.OrdinalIgnoreCase))
        {
            if (col.IsFk)
            {
                <form id="drop-ref-@(tableName)-@(col.ColumnName)" method="post" action="/drop_reference/@tableName">
                    <input type="hidden" name="column_name" value="@col.ColumnName"/>
                </form>
            }
            else
            {
                <form id="drop-col-@(tableName)-@(col.ColumnName)" method="post" action="/drop_column/@tableName">
                    <input type="hidden" name="column_name" value="@col.ColumnName"/>
                </form>
            }
        }
    }

    <div class="card mb-3 schema-card" data-name="@entity.DisplayName.ToLower()" data-table="@tableName.ToLower()">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi @entity.Icon me-2"></i>@entity.DisplayName</h5>
            <button type="submit" form="drop-tbl-@tableName" class="btn btn-sm btn-danger" style="width:90px">
                <i class="bi bi-trash me-1"></i>Drop
            </button>
        </div>
        <div class="card-body p-0">
            <table class="table table-sm table-bordered mb-0">
                <thead><tr><th>Name</th><th>Type</th><th>FK</th><th>Nullable</th><th style="width:90px"></th></tr></thead>
                <tbody>
                @foreach (var col in entity.Columns)
                {
                    var isPk = pkCols.Contains(col.ColumnName);
                    <tr>
                        <td>@col.ColumnName</td>
                        <td>@col.DataType</td>
                        <td>@(col.IsFk ? col.FkRefTable : "")</td>
                        <td>@(col.IsNullable ? "Yes" : "No")</td>
                        <td class="text-nowrap">
                            @if (!isPk && !col.ColumnName.Equals("NAME", StringComparison.OrdinalIgnoreCase))
                            {
                                var formId = col.IsFk
                                    ? $"drop-ref-{tableName}-{col.ColumnName}"
                                    : $"drop-col-{tableName}-{col.ColumnName}";
                                <button type="submit" form="@formId" class="btn btn-sm btn-danger w-100">
                                    <i class="bi bi-x-lg me-1"></i>Drop
                                </button>
                            }
                        </td>
                    </tr>
                }
                <tr class="table-light">
                    <td><input form="add-col-@tableName" type="text" name="column_name" class="form-control form-control-sm" placeholder="Column name"/></td>
                    <td>
                        <select form="add-col-@tableName" name="column_type" class="form-select form-select-sm">
                            <option value="VARCHAR2(200)">Text</option>
                            <option value="NUMBER">Number</option>
                            <option value="DATE">Date</option>
                            <option value="TIMESTAMP">Timestamp</option>
                        </select>
                    </td>
                    <td>
                        <select form="add-col-@tableName" name="ref_table" class="form-select form-select-sm">
                            <option value="">—</option>
                            @foreach (var e in allEntities)
                            {
                                <option value="@e.TableName">@e.DisplayName</option>
                            }
                        </select>
                    </td>
                    <td class="text-center"><input form="add-col-@tableName" type="checkbox" name="nullable" class="form-check-input" checked/></td>
                    <td><button type="submit" form="add-col-@tableName" class="btn btn-sm btn-danger w-100"><i class="bi bi-plus-lg me-1"></i>Add</button></td>
                </tr>
                </tbody>
            </table>
        </div>
    </div>
}
<p id="noResults" class="text-muted text-center mt-4 d-none">No matching tables.</p>

@section Scripts {
<script>
(function(){
    var input = document.getElementById('schemaSearch');
    var cards = document.querySelectorAll('.schema-card');
    var noResults = document.getElementById('noResults');

    input.addEventListener('input', function(){
        var f = this.value.toLowerCase().trim();
        var vis = 0;
        cards.forEach(function(c){
            var m = !f || c.dataset.name.includes(f) || c.dataset.table.includes(f);
            c.style.display = m ? '' : 'none';
            if(m) vis++;
        });
        noResults.classList.toggle('d-none', vis > 0 || !f);
    });
}());
</script>
}
