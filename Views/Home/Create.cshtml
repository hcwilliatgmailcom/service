@{
    var entity = (EntityMeta)ViewBag.Entity;
    var tableName = (string)ViewBag.TableName;
    var fkOptions = (Dictionary<string, List<Dictionary<string, object?>>>)ViewBag.FkOptions;
    ViewData["Title"] = "Create " + entity.DisplayName;
}
<h1>Create @entity.DisplayName</h1>
<hr/>
<div class="row">
    <div class="col-md-6">
        <form method="post" action="/entity/@tableName/create">
            @foreach (var col in entity.Columns)
            {
                if (entity.PkColumns.Contains(col.ColumnName) && col.IsIdentity)
                {
                    continue;
                }
                if (col.IsFk)
                {
                    var navName = col.FkNavName ?? SchemaService.SplitPascal(col.FkRefTable!);
                    var opts = fkOptions.ContainsKey(col.ColumnName) ? fkOptions[col.ColumnName] : new List<Dictionary<string, object?>>();
                    <div class="form-group mb-3 fk-wrapper">
                        <label class="control-label">@navName</label>
                        <input type="hidden" name="@col.ColumnName" id="@col.ColumnName" value=""/>
                        <input type="text" class="form-control fk-autocomplete" id="display_@col.ColumnName" data-target="@col.ColumnName" autocomplete="off"/>
                        <div class="fk-dropdown" id="dropdown_@col.ColumnName">
                            @foreach (var opt in opts)
                            {
                                <div class="fk-option" data-id="@opt["PK"]" data-text="@opt["DISPLAY"]">@opt["DISPLAY"]</div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    var label = SchemaService.SplitPascal(col.ColumnName);
                    var dt = col.DataType.ToUpper();
                    <div class="form-group mb-3">
                        <label class="control-label" for="@col.ColumnName">@label</label>
                        @if (dt.Contains("NUMBER") || dt.Contains("INT"))
                        {
                            <input name="@col.ColumnName" class="form-control" type="number"/>
                        }
                        else if (dt == "DATE")
                        {
                            <input name="@col.ColumnName" class="form-control" type="date"/>
                        }
                        else if (dt.Contains("TIMESTAMP"))
                        {
                            <input name="@col.ColumnName" class="form-control" type="datetime-local"/>
                        }
                        else
                        {
                            <input name="@col.ColumnName" class="form-control" type="text"/>
                        }
                    </div>
                }
            }
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary"/>
            </div>
        </form>
    </div>
</div>
<div class="mt-3"><a href="/entity/@tableName">Back to List</a></div>

@section Scripts {
<script src="/js/fk-autocomplete.js"></script>
}
