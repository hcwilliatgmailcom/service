@{
    ViewData["Title"] = "Sign In";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Sign In - CMDB</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
    <style>
        body { background: #f8f9fa; }
        .login-card {
            max-width: 400px;
            margin: 10vh auto 0;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h4 class="card-title mb-4">CMDB Sign In</h4>

                @if (TempData["Flash"] is string flash)
                {
                    var parts = flash.Split('|', 2);
                    <div class="alert alert-@parts[0] alert-dismissible fade show" role="alert">
                        @parts[1]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @if (TempData["MagicLink"] is string magicLink)
                {
                    <div class="alert alert-info">
                        <a href="@magicLink">Click here to sign in</a>
                    </div>
                }

                <form method="post" action="/login">
                    <div class="mb-3">
                        <label for="email" class="form-label">Email address</label>
                        <input type="email" class="form-control" id="email" name="email"
                               placeholder="you@example.com" required autofocus/>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Send login link</button>
                </form>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
