<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - CMDB</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <style>
        body { padding-bottom: 40px; }
        .fk-wrapper { position: relative; }
        .fk-dropdown {
            display: none; position: absolute; z-index: 1050; width: 100%;
            background: #fff; border: 1px solid #dfe1e5; border-top: none;
            border-radius: 0 0 8px 8px; box-shadow: 0 4px 16px rgba(0,0,0,.2);
            max-height: 280px; overflow-y: auto;
        }
        .fk-option {
            padding: 9px 16px; cursor: pointer; font-size: .9rem;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .fk-option:hover, .fk-option.fk-active { background: #f1f3f4; }
        .fk-autocomplete:focus { border-radius: 8px 8px 0 0; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" href="/">CMDB</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navContent">
                    <span class="navbar-toggler-icon"></span>
                </button>
                @{var navEmail = Context.Session.GetString("email");}
                <div class="collapse navbar-collapse" id="navContent">
                    @if (navEmail != null)
                    {
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item"><a class="nav-link text-dark" href="/">Home</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" href="/schema">Schema</a></li>
                        </ul>
                        <ul class="navbar-nav ms-auto">
                            <li class="nav-item"><span class="nav-link text-muted small">@navEmail</span></li>
                            <li class="nav-item"><a class="nav-link text-dark" href="/logout">Sign out</a></li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        @{
            var flash = TempData["Flash"] as string
                     ?? Context.Session.GetString("_flash");
            if (flash != null) Context.Session.Remove("_flash");
        }
        @if (flash != null)
        {
            var parts = flash.Split('|', 2);
            <div class="alert alert-@parts[0] alert-dismissible fade show">@parts[1]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        <main role="main" class="pb-3">@RenderBody()</main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
