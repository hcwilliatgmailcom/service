@{
    ViewData["Title"] = "Import " + (string)ViewData["EntityDisplayName"]!;
    var properties = (List<Dictionary<string, object>>)ViewData["Properties"]!;
    var controllerName = (string)ViewData["ControllerName"]!;
}

<h1>Import @ViewData["EntityDisplayName"]</h1>

 
<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <form asp-action="Import" asp-controller="@controllerName" method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="file" class="form-label">Excel File (.xlsx)</label>
                        <input type="file" name="file" id="file" class="form-control" accept=".xlsx" required />
                    </div>
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-upload me-1"></i>Import
                    </button>
                    <a asp-action="Index" asp-controller="@controllerName" class="btn btn-secondary ms-2">Cancel</a>
                </form>
            </div>
        </div>

 
 
    </div>
</div>
