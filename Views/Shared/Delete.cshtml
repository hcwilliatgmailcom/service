@model dynamic
@{
    ViewData["Title"] = "Delete " + (string)ViewData["EntityDisplayName"]!;
    var properties = (List<Dictionary<string, object>>)ViewData["Properties"]!;
    var foreignKeys = (Dictionary<string, Dictionary<string, string>>)ViewData["ForeignKeys"]!;
    var controllerName = (string)ViewData["ControllerName"]!;
    var primaryKeys = (List<string>)ViewData["PrimaryKeys"]!;
    var routeKeys = (List<string>)ViewData["RouteKeys"]!;

    var modelObj = (object)Model;
    var modelType = modelObj.GetType();
}

<h1>Delete @ViewData["EntityDisplayName"]</h1>

<h3>Are you sure you want to delete this?</h3>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div>
    <h4>@ViewData["EntityDisplayName"]</h4>
    <hr />
    <dl class="row">
        @foreach (var prop in properties)
        {
            var name = (string)prop["Name"];
            var isPK = (bool)prop["IsPK"];
            var isFK = (bool)prop["IsFK"];

            if (isFK && foreignKeys.ContainsKey(name))
            {
                var fk = foreignKeys[name];
                var navPropInfo = modelType.GetProperty(fk["NavigationProperty"]);
                var navObj = navPropInfo?.GetValue(modelObj);
                var displayValue = navObj?.GetType().GetProperty(fk["DisplayMember"])?.GetValue(navObj);
                <dt class="col-sm-2">@fk["NavigationProperty"]</dt>
                <dd class="col-sm-10">@displayValue</dd>
            }
            else
            {
                var value = modelType.GetProperty(name)?.GetValue(modelObj);
                <dt class="col-sm-2">@name</dt>
                <dd class="col-sm-10">@value</dd>
            }
        }
    </dl>

    <form asp-action="Delete" asp-controller="@controllerName" method="post">
        @for (int i = 0; i < primaryKeys.Count; i++)
        {
            var pkValue = modelType.GetProperty(primaryKeys[i])?.GetValue(modelObj);
            <input type="hidden" name="@routeKeys[i]" value="@pkValue" />
        }
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index" asp-controller="@controllerName">Back to List</a>
    </form>
</div>
