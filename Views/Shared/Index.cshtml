@model dynamic
@{
    ViewData["Title"] = (string)ViewData["EntityDisplayName"]!;
    var properties = (List<Dictionary<string, object>>)ViewData["Properties"]!;
    var foreignKeys = (Dictionary<string, Dictionary<string, string>>)ViewData["ForeignKeys"]!;
    var controllerName = (string)ViewData["ControllerName"]!;
    var primaryKeys = (List<string>)ViewData["PrimaryKeys"]!;
    var routeKeys = (List<string>)ViewData["RouteKeys"]!;
}

<h1>@ViewData["EntityDisplayName"]</h1>

<form asp-action="Index" asp-controller="@controllerName" method="get" class="form-inline mb-3">
    <input type="hidden" name="sortOrder" value="@ViewData["CurrentSort"]" />
    <div class="input-group">
        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search..." />
        <button type="submit" class="btn btn-primary me-2">
            <i class="bi bi-search me-1"></i>Search
        </button>
        @if (!string.IsNullOrEmpty((string?)ViewData["CurrentFilter"]))
        {
            <a asp-action="Index" asp-controller="@controllerName" class="btn btn-outline-secondary me-2">Clear</a>
        }
        <a asp-action="Create" asp-controller="@controllerName" class="btn btn-danger me-2">
            <i class="bi bi-plus-circle me-1"></i>Create
        </a>
    </div>
</form>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["ImportResult"] != null)
{
    <div class="alert alert-success">@TempData["ImportResult"]</div>
}

<table class="table table-striped">
    <thead>
        <tr>
            @{
                var pkProp = properties.FirstOrDefault(p => (bool)p["IsPK"]);
            }
            @if (pkProp != null)
            {
                var pkName = (string)pkProp["Name"];
                var sortParm = ViewData[pkName + "SortParm"];
                <th>
                    <a asp-action="Index" asp-controller="@controllerName"
                       asp-route-sortOrder="@sortParm"
                       asp-route-searchString="@ViewData["CurrentFilter"]">@pkName</a>
                </th>
            }
            @foreach (var prop in properties)
            {
                var name = (string)prop["Name"];
                var isPK = (bool)prop["IsPK"];
                var isFK = (bool)prop["IsFK"];

                if (isPK) continue;

                if (isFK && foreignKeys.ContainsKey(name))
                {
                    var fk = foreignKeys[name];
                    var sortParm = ViewData[fk["NavigationProperty"] + "SortParm"];
                    <th>
                        <a asp-action="Index" asp-controller="@controllerName"
                           asp-route-sortOrder="@sortParm"
                           asp-route-searchString="@ViewData["CurrentFilter"]">@fk["NavigationProperty"]</a>
                    </th>
                }
                else
                {
                    var sortParm = ViewData[name + "SortParm"];
                    <th>
                        <a asp-action="Index" asp-controller="@controllerName"
                           asp-route-sortOrder="@sortParm"
                           asp-route-searchString="@ViewData["CurrentFilter"]">@name</a>
                    </th>
                }
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var itemObj = (object)item;
            var itemType = itemObj.GetType();
            <tr>
                @{
                    var rv = new Dictionary<string, string>();
                    for (int i = 0; i < primaryKeys.Count; i++)
                    {
                        rv[routeKeys[i]] = itemType.GetProperty(primaryKeys[i])?.GetValue(itemObj)?.ToString() ?? "";
                    }
                    var idDisplay = string.Join(", ", primaryKeys.Select(pk => itemType.GetProperty(pk)?.GetValue(itemObj)));
                }
                <td>
                    <a asp-action="Edit" asp-controller="@controllerName" asp-all-route-data="@rv">@idDisplay</a>
                </td>
                @foreach (var prop in properties)
                {
                    var name = (string)prop["Name"];
                    var isPK = (bool)prop["IsPK"];
                    var isFK = (bool)prop["IsFK"];

                    if (isPK) continue;

                    if (isFK && foreignKeys.ContainsKey(name))
                    {
                        var fk = foreignKeys[name];
                        var navPropInfo = itemType.GetProperty(fk["NavigationProperty"]);
                        var navObj = navPropInfo?.GetValue(itemObj);
                        var displayValue = navObj?.GetType().GetProperty(fk["DisplayMember"])?.GetValue(navObj);
                        <td>@displayValue</td>
                    }
                    else
                    {
                        var value = itemType.GetProperty(name)?.GetValue(itemObj);
                        <td>@value</td>
                    }
                }
            </tr>
        }
    </tbody>
</table>

@{
    int pageIndex = (int)ViewData["PageIndex"]!;
    int totalPages = (int)ViewData["TotalPages"]!;
    bool hasPreviousPage = (bool)ViewData["HasPreviousPage"]!;
    bool hasNextPage = (bool)ViewData["HasNextPage"]!;
}

<div class="d-flex justify-content-between align-items-center">
    <nav>
        <ul class="pagination mb-0">
            @if (hasPreviousPage)
            {
                <li class="page-item">
                    <a asp-action="Index" asp-controller="@controllerName"
                       asp-route-sortOrder="@ViewData["CurrentSort"]"
                       asp-route-searchString="@ViewData["CurrentFilter"]"
                       asp-route-pageNumber="@(pageIndex - 1)"
                       class="page-link">Previous</a>
                </li>
            }
            else
            {
                <li class="page-item disabled"><span class="page-link">Previous</span></li>
            }

            <li class="page-item disabled"><span class="page-link">Page @pageIndex of @totalPages</span></li>

            @if (hasNextPage)
            {
                <li class="page-item">
                    <a asp-action="Index" asp-controller="@controllerName"
                       asp-route-sortOrder="@ViewData["CurrentSort"]"
                       asp-route-searchString="@ViewData["CurrentFilter"]"
                       asp-route-pageNumber="@(pageIndex + 1)"
                       class="page-link">Next</a>
                </li>
            }
            else
            {
                <li class="page-item disabled"><span class="page-link">Next</span></li>
            }
        </ul>
    </nav>
    <div>
        <a asp-action="Export" asp-controller="@controllerName" class="btn btn-warning me-2">
            <i class="bi bi-download me-1"></i>Export
        </a>
        <a asp-action="Import" asp-controller="@controllerName" class="btn btn-warning me-2">
            <i class="bi bi-upload me-1"></i>Import
        </a>
        @if (ViewData["SyncAvailable"] is true)
        {
            <form asp-action="Sync" asp-controller="@controllerName" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-arrow-repeat me-1"></i>Sync
                </button>
            </form>
        }
    </div>
</div>
