@model dynamic
@{
    ViewData["Title"] = "Create " + (string)ViewData["EntityDisplayName"]!;
    var properties = (List<Dictionary<string, object>>)ViewData["Properties"]!;
    var foreignKeys = (Dictionary<string, Dictionary<string, string>>)ViewData["ForeignKeys"]!;
    var controllerName = (string)ViewData["ControllerName"]!;
}

<h1>Create @ViewData["EntityDisplayName"]</h1>

<h4>@ViewData["EntityDisplayName"]</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" asp-controller="@controllerName" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            @foreach (var prop in properties)
            {
                var name = (string)prop["Name"];
                var typeName = (string)prop["Type"];
                var isPK = (bool)prop["IsPK"];
                var isFK = (bool)prop["IsFK"];

                if (isPK) continue;

                if (isFK && foreignKeys.ContainsKey(name))
                {
                    var fk = foreignKeys[name];
                    var selectList = ViewData[name] as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
                    <div class="form-group mb-3 fk-wrapper">
                        <label class="control-label">@fk["NavigationProperty"]</label>
                        <input type="hidden" name="@name" id="@name" value="" />
                        <input type="text" class="form-control fk-autocomplete"
                               id="display_@name"
                               data-target="@name"
                               autocomplete="off" />
                        <div class="fk-dropdown" id="dropdown_@name">
                            @if (selectList != null)
                            {
                                @foreach (var item in selectList)
                                {
                                    <div class="fk-option" data-id="@item.Value" data-text="@item.Text">@item.Text</div>
                                }
                            }
                        </div>
                        <span class="text-danger" data-valmsg-for="@name" data-valmsg-replace="true"></span>
                    </div>
                }
                else
                {
                    var inputType = "text";
                    var step = "";
                    if (typeName == "int" || typeName == "Int32" || typeName == "Nullable<int>")
                    {
                        inputType = "number";
                    }
                    else if (typeName == "decimal" || typeName == "Decimal" || typeName == "Nullable<decimal>")
                    {
                        inputType = "number";
                        step = "0.01";
                    }
                    else if (typeName == "DateOnly" || typeName == "Nullable<DateOnly>" || typeName == "DateOnly?")
                    {
                        inputType = "date";
                    }

                    <div class="form-group mb-3">
                        <label class="control-label" for="@name">@name</label>
                        <input name="@name" class="form-control" type="@inputType"
                               @(step != "" ? $"step=\"{step}\"" : "") />
                        <span class="text-danger" data-valmsg-for="@name" data-valmsg-replace="true"></span>
                    </div>
                }
            }
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index" asp-controller="@controllerName">Back to List</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_FKAutocomplete" />
}
