@inherits Microsoft.VisualStudio.Web.CodeGeneration.Templating.RazorTemplateBase
@using Microsoft.VisualStudio.Web.CodeGeneration.EntityFrameworkCore
@using System.Collections.Generic
@using System.Linq
@@model @Model.ViewDataTypeName

@{
    var navigationLookup = ((IModelMetadata)Model.ModelMetadata).Navigations.ToDictionary(x => x.ForeignKeyPropertyNames[0], x => x);
    var navDisplayMembers = new Dictionary<string, string>();
    foreach (var nav in ((IModelMetadata)Model.ModelMetadata).Navigations)
    {
        string displayMember = nav.DisplayPropertyName;
        var navPropInfo = Model.ModelMetadata.ModelType.GetProperty(nav.AssociationPropertyName);
        if (navPropInfo != null)
        {
            var nameProp = navPropInfo.PropertyType.GetProperty("Name");
            if (nameProp != null && nameProp.PropertyType == typeof(string))
            {
                displayMember = "Name";
            }
            else
            {
                foreach (var p in navPropInfo.PropertyType.GetProperties())
                {
                    if (p.PropertyType == typeof(string))
                    {
                        displayMember = p.Name;
                        break;
                    }
                }
            }
        }
        navDisplayMembers[nav.AssociationPropertyName] = displayMember;
    }
    var controllerName = Model.ViewDataTypeName;
    if (controllerName.Contains("."))
    {
        controllerName = controllerName.Substring(controllerName.LastIndexOf('.') + 1);
    }
}
@{
    if (Model.IsPartialView)
    {
    }
    else if (Model.IsLayoutPageSelected)
    {
@:@@{
    @:ViewData["Title"] = "@Model.ViewName";
        if (!string.IsNullOrEmpty(Model.LayoutPageFile))
        {
    @:Layout = "@Model.LayoutPageFile";
        }
@:}
@:
@:
    }
    else
    {
@:@@{
    @:Layout = null;
@:}
@:
@:<!DOCTYPE html>
@:
@:<html>
@:<head>
    @:<meta name="viewport" content="width=device-width" />
    @:<title>@Model.ViewName</title>
@:</head>
@:<body>
@:
        //    PushIndent("    ");
    }
@:<form asp-action="@Model.ViewName">
    @:<div asp-validation-summary="ModelOnly" class="text-danger"></div>
        foreach (var property in Model.ModelMetadata.Properties)
        {
            if (property.Scaffold && !property.IsAutoGenerated && !property.IsReadOnly)
            {
                if (property.IsForeignKey)
                {
                    if (navigationLookup.TryGetValue(property.PropertyName, out INavigationMetadata navMeta))
                    {
                        var navAssoc = navMeta.AssociationPropertyName;
                        var navDisplay = navDisplayMembers[navAssoc];
                        var navTypeName = Model.ModelMetadata.ModelType.GetProperty(navAssoc).PropertyType.Name;
            @:<div class="form-group row mb-2 align-items-center">
                @:<label asp-for="@property.PropertyName" class="col-sm-2 col-form-label fw-bold"></label>
                @:<div class="col">
                    @:<input type="text" class="form-control" name="@property.PropertyName" id="@property.PropertyName" value="@@(Model?.@(navAssoc) != null ? $"{Model.@(navAssoc).@(navDisplay)} [{Model.@(property.PropertyName)}]" : "")" placeholder="Search @(navAssoc)..." data-search-url="@@Url.Action("Search@(navAssoc)", "@controllerName")" autocomplete="off" />
                    @:<div id="@(property.PropertyName)_Results" class="list-group" style="position:absolute;z-index:1000;"></div>
                    @:<span asp-validation-for="@property.PropertyName" class="text-danger"></span>
                @:</div>
                @:<div class="col-auto">
                    @:<a asp-controller="@navTypeName" asp-action="Index" target="_blank" class="badge bg-secondary text-decoration-none">List</a>
                    @:@@if (Model?.@(property.PropertyName) != null) {
                    @:<a asp-controller="@navTypeName" asp-action="Details" asp-route-id="@@Model.@(property.PropertyName)" target="_blank" class="badge bg-info text-decoration-none">Show</a>
                    @:}
                    @:<a asp-controller="@navTypeName" asp-action="Create" target="_blank" class="badge bg-success text-decoration-none">New</a>
                @:</div>
            @:</div>
                    }
                    else
                    {
            @:<div class="form-group row mb-2">
                @:<label asp-for="@property.PropertyName" class="col-sm-2 col-form-label"></label>
                @:<div class="col-sm-10">
                    @:<select asp-for="@property.PropertyName" class="form-control" asp-items="ViewBag.@property.PropertyName"></select>
                @:</div>
            @:</div>
                    }
                    continue;
                }

                bool isCheckbox = property.TypeName.Equals("System.Boolean");
                if (isCheckbox)
                {
            @:<div class="form-group row mb-2">
                @:<label class="col-sm-2 col-form-label">
                    @:<input class="form-check-input" asp-for="@property.PropertyName" /> @@Html.DisplayNameFor(model => model.@GetValueExpression(property))
                @:</label>
            @:</div>
                }
                else if (property.IsEnum && !property.IsEnumFlags)
                {
            @:<div class="form-group row mb-2">
                @:<label asp-for="@property.PropertyName" class="col-sm-2 col-form-label"></label>
                @:<div class="col-sm-10">
                    @:<select asp-for="@property.PropertyName" class="form-control"></select>
                    @:<span asp-validation-for="@property.PropertyName" class="text-danger"></span>
                @:</div>
            @:</div>
                }
                else if (property.IsMultilineText)
                {
            @:<div class="form-group row mb-2">
                @:<label asp-for="@property.PropertyName" class="col-sm-2 col-form-label"></label>
                @:<div class="col-sm-10">
                    @:<textarea asp-for="@property.PropertyName" class="form-control"></textarea>
                    @:<span asp-validation-for="@property.PropertyName" class="text-danger"></span>
                @:</div>
            @:</div>
                }
                else
                {
            @:<div class="form-group row mb-2">
                @:<label asp-for="@property.PropertyName" class="col-sm-2 col-form-label"></label>
                @:<div class="col-sm-10">
                    @:<input asp-for="@property.PropertyName" class="form-control" />
                    @:<span asp-validation-for="@property.PropertyName" class="text-danger"></span>
                @:</div>
            @:</div>
                }
            }
        }
        }
            <div class="form-group row mb-2">
                <div class="col-sm-10 offset-sm-2">
                    <input type="submit" value="Create" class="btn btn-primary" />
                </div>
            </div>
        </form>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@{
    if (Model.ReferenceScriptLibraries)
    {
@:@@section Scripts {
    @:@@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    @:<script src="~/js/autocomplete.js"></script>
@:}
    }
    // The following code closes the tag used in the case of a view using a layout page and the body and html tags in the case of a regular view page
    if (!Model.IsPartialView && !Model.IsLayoutPageSelected)
    {
@:</body>
@:</html>
    }
}
@functions
{
    // Do we need to use this in conjunction with the PrimaryKey check?
    bool IsPropertyGuid(IPropertyMetadata property)
    {
        return string.Equals("System.Guid", property.TypeName, StringComparison.OrdinalIgnoreCase);
    }

    string GetValueExpression(IPropertyMetadata property)
    {
        return property.PropertyName;
    }
}
