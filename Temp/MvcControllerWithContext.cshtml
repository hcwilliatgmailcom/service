            {
                searchConditions.Add(String.Format("({0}.{1} != null && {0}.{1}.{2} != null && {0}.{1}.{2}.Contains(searchString))", lambdaVar, nav.AssociationPropertyName, nav.DisplayPropertyName));
            }
        }
    }
    if (searchConditions.Count > 0)
    {
        var whereClause = String.Join(" || ", searchConditions);
            @:    @entitySetVar = @(entitySetVar).Where(@(lambdaVar) => @whereClause);
    }
            @:}
            @:
