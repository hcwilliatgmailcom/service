    var navDisplayMembers = new Dictionary<string, string>();
    foreach (var nav in relatedProperties.Values)
    {
        string displayMember = (string)nav.DisplayPropertyName;
        var navPropInfo = Model.ModelMetadata.ModelType.GetProperty((string)nav.AssociationPropertyName);
        if (navPropInfo != null)
        {
            var nameProp = navPropInfo.PropertyType.GetProperty("Name");
            if (nameProp != null && nameProp.PropertyType == typeof(string))
            {
                displayMember = "Name";
            }
            else
            {
                foreach (var p in navPropInfo.PropertyType.GetProperties())
                {
                    if (p.PropertyType == typeof(string))
                    {
                        displayMember = p.Name;
                        break;
                    }
                }
            }
        }
        navDisplayMembers[(string)nav.AssociationPropertyName] = displayMember;
    }

    var inlineIncludes = "";
    foreach (var property in relatedProperties.Values)
    {
        inlineIncludes += string.Format("{0}                .Include({1} => {1}.{2})", Environment.NewLine, lambdaVar, property.AssociationPropertyName);
    }

    if (!string.IsNullOrEmpty(Model.AreaName))
