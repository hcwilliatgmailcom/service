            @:        break;
            @:    case "@nav.AssociationPropertyName":
            @:        @entitySetVar = @(entitySetVar).OrderBy(@(lambdaVar) => @(lambdaVar).@(nav.AssociationPropertyName).@navSortMember);
            @:        break;
    }
            @:    default:
    string defaultPropertyName = null;
    foreach (var prop in Model.ModelMetadata.Properties)
    {
        if (prop.Scaffold && !prop.IsForeignKey && !prop.IsPrimaryKey)
        {
            defaultPropertyName = prop.PropertyName;
            break;
        }
    }
    if (defaultPropertyName != null)
    {
            @:        @entitySetVar = @(entitySetVar).OrderBy(@(lambdaVar) => @(lambdaVar).@defaultPropertyName);
    }
            @:        break;
            @:}
            @:
            @:int pageSize = 10;
            @:SetViewMetadata();
            @:return View(await PaginatedList<@(Model.ModelTypeName)>.CreateAsync(@(entitySetVar), pageNumber ?? 1, pageSize));
}        }

        // GET: @routePrefix/Details/5
        public async Task<IActionResult> Details(@primaryKeyNullableTypeName id)
